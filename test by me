import sqlite3
import random
from datetime import datetime, timedelta

DB_PATH = "reviews.db"

def seed_data():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    # Clear existing data for a clean demo
    cursor.execute("DELETE FROM issues")
    cursor.execute("DELETE FROM prs")

    repos = ["hcl-project", "ai-reviewer-engine", "frontend-core"]
    severities = ["high", "medium", "low"]
    types = ["security", "bug", "performance", "quality"]

    descriptions = {
        "security": ["Hardcoded API Key found", "Potential SQL Injection", "Insecure JWT implementation", "Missing CSRF protection"],
        "bug": ["Null pointer exception risk", "Infinite loop in data processing", "Incorrect index handling", "Variable shadow risk"],
        "performance": ["O(n^2) loop detected", "Redundant DB connection creation", "Large asset loading in main thread", "Missing index on query"],
        "quality": ["Missing docstring", "Variable name 'x' is too vague", "Function too complex", "Redundant code block"]
    }

    print("🚀 Seeding demo data...")

    # Seed 12 mock PRs
    for i in range(12):
        repo = random.choice(repos)
        pr_num = 100 + i
        # Spread dates over the last few days
        date = (datetime.now() - timedelta(days=random.randint(0, 5), hours=random.randint(0, 23))).isoformat()
        status = "success" if random.random() > 0.1 else "failed"

        cursor.execute("INSERT INTO prs (repo, pr_number, reviewed_at, status) VALUES (?, ?, ?, ?)",
                      (repo, pr_num, date, status))
        pr_id = cursor.lastrowid

        # Add 1-5 issues per PR
        num_issues = random.randint(1, 5)
        for _ in range(num_issues):
            i_type = random.choice(types)
            i_sev = random.choice(severities)
            i_desc = random.choice(descriptions[i_type])
            i_file = f"src/module_{random.randint(1,5)}.py"
            i_line = random.randint(10, 500)

            cursor.execute("INSERT INTO issues (pr_id, severity, type, description, file, line) VALUES (?, ?, ?, ?, ?, ?)",
                          (pr_id, i_sev, i_type, i_desc, i_file, i_line))

    # Update system meta start time
    cursor.execute("INSERT OR REPLACE INTO system_meta (key, value) VALUES (?, ?)",
                  ("bot_start_time", (datetime.now() - timedelta(hours=48)).isoformat()))

    conn.commit()
    conn.close()
    print("✅ Demo data seeded! Refresh your dashboard now.")

if __name__ == "__main__":
    seed_data()
